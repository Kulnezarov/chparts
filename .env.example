# ========== CHParts (витрина Next.js) — переменные окружения ==========
# Скопируйте в .env.local для разработки или задайте на сервере перед npm run build

# --- Разработка (localhost) ---
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Продакшен (пример, замените на свои значения) ---
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_SITE_URL=https://chparts.kz

# Важно:
# 1) NEXT_PUBLIC_SITE_URL — ваш домен с HTTPS (для SEO, Open Graph, sitemap, canonical)
# 2) NEXT_PUBLIC_API_BASE_URL — URL бэкенда SkladPro (rewrite /api/proxy/* задаётся при сборке!)
# 3) Опционально для SSR на VPS/Docker — внутренний URL бэкенда (быстрее loopback):
# API_BASE_URL=http://backend:8000
# 4) Переменные NEXT_PUBLIC_* должны быть заданы ДО команды npm run build

# Опционально (Google Search Console — добавьте в app/layout.tsx metadata.verification):
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxx
